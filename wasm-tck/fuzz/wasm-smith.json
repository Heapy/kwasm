{
  "allow-start-export": false,
  "allow-floats": true,
  "allow-invalid-funcs": false,
  "bulk-memory-enabled": true,
  "canonicalize-nans": true,
  "custom-descriptors-enabled": false,
  "custom-page-sizes-enabled": false,
  "disallow-traps": false,
  "exceptions-enabled": false,
  "export-everything": false,
  "extended-const-enabled": false,
  "gc-enabled": false,
  "generate-custom-sections": false,
  "max-data-segments": 8,
  "max-element-segments": 8,
  "max-elements": 32,
  "max-exports": 16,
  "max-funcs": 32,
  "max-globals": 32,
  "max-imports": 0,
  "max-instructions": 80,
  "max-memories": 1,
  "max-memory32-bytes": 4194304,
  "max-memory64-bytes": 4194304,
  "max-table-elements": 1024,
  "max-tables": 1,
  "max-tags": 0,
  "max-type-size": 128,
  "max-types": 32,
  "memory-max-size-required": true,
  "memory64-enabled": false,
  "min-data-segments": 0,
  "min-element-segments": 0,
  "min-elements": 0,
  "min-exports": 4,
  "min-funcs": 4,
  "min-globals": 0,
  "min-imports": 0,
  "min-memories": 0,
  "min-tables": 0,
  "min-tags": 0,
  "min-types": 1,
  "multi-value-enabled": true,
  "reference-types-enabled": false,
  "relaxed-simd-enabled": false,
  "saturating-float-to-int-enabled": true,
  "shared-everything-threads-enabled": false,
  "sign-extension-ops-enabled": true,
  "simd-enabled": false,
  "table-max-size-required": true,
  "tail-call-enabled": false,
  "threads-enabled": false,
  "wide-arithmetic-enabled": false
}
